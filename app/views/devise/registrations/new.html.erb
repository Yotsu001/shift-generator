<section class="page-shell page-shell--narrow auth-page">
  <div class="page-header">
    <div>
      <p class="eyebrow">アカウント</p>
      <h1 class="page-title">新規登録</h1>
      <p class="page-subtitle">初めての方でも迷いにくいよう、入力項目を落ち着いたトーンでまとめています。</p>
    </div>
  </div>

  <section class="card auth-card auth-card--form">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "stacked-form auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :name, "名前" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name" %>
      </div>

      <div class="form-group">
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email, autocomplete: "email" %>
      </div>

      <div class="form-group">
        <div class="auth-form__label-row">
          <%= f.label :password, "パスワード" %>
          <% if @minimum_password_length %>
            <span class="form-hint"><%= @minimum_password_length %>文字以上</span>
          <% end %>
        </div>
        <%= f.password_field :password, autocomplete: "new-password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "パスワード（確認用）" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="form-actions">
        <%= f.submit "新規登録" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </section>
</section>
