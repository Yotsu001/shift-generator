<section class="page-shell page-shell--narrow auth-page">
  <div class="page-header">
    <div>
      <p class="eyebrow">アカウント</p>
      <h1 class="page-title">ログイン</h1>
      <p class="page-subtitle">ユーザー登録済みの方はログインしてください。未登録の方は新規登録をお願いします。</p>
    </div>
  </div>

  <section class="card auth-card auth-card--form">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "stacked-form auth-form" }) do |f| %>
      <div class="form-group">
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "パスワード" %>
        <%= f.password_field :password, autocomplete: "current-password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-group form-group--inline auth-checkbox-row">
          <%= f.label :remember_me, "ログイン状態を保持する" %>
          <%= f.check_box :remember_me %>
        </div>
      <% end %>

      <div class="form-actions">
        <%= f.submit "ログイン" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </section>
</section>
