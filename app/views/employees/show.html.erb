<h1>スタッフ詳細</h1>

<p>
  <strong>ID:</strong>
  <%= @employee.id %>
</p>

<p>
  <strong>スタッフ名:</strong>
  <%= @employee.name %>
</p>

<p>
  <strong>主担当区:</strong>
  <%= @employee.primary_zone&.name || '未設定' %>
</p>

<p>
  <strong>担当可能区:</strong>
  <%= @employee.zones.order(:position).pluck(:name).join('、').presence || '未設定' %>
</p>

<p>
  <strong>土日祝出勤不可:</strong>
  <%= @employee.weekend_work_disabled ? 'する' : 'しない' %>
</p>

<% if @employee.has_attribute?(:mixed_zone_preferred) %>
  <p>
    <strong>混合区担当候補:</strong>
    <%= @employee.mixed_zone_preferred ? 'する' : 'しない' %>
  </p>
<% end %>

<p>
  <%= link_to '編集', edit_employee_path(@employee) %> |
  <%= link_to 'スタッフ一覧へ戻る', employees_path %>
</p>
