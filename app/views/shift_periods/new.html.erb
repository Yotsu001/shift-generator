<section class="page-shell page-shell--narrow">
  <div class="page-header">
    <div>
      <p class="eyebrow">Shift Periods</p>
      <h1 class="page-title">シフト期間作成</h1>
      <p class="page-subtitle">期間名、日付、状態を順に登録できる、やわらかな入力画面です。</p>
    </div>
  </div>

  <section class="card">
    <%= form_with model: @shift_period, local: true, html: { class: "stacked-form" } do |f| %>
      <% if @shift_period.errors.any? %>
        <div class="error-messages">
          <ul>
            <% @shift_period.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :name, "名称" %>
        <%= f.text_field :name %>
      </div>

      <div class="form-row">
        <div class="form-group">
          <%= f.label :start_date, "開始日" %>
          <%= f.date_field :start_date %>
        </div>

        <div class="form-group">
          <%= f.label :end_date, "終了日" %>
          <%= f.date_field :end_date %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :status, "状態" %>
        <%= f.select :status, ShiftPeriod.statuses.keys.map { |k| [k, k] } %>
      </div>

      <div class="form-actions">
        <%= f.submit "作成する" %>
      </div>
    <% end %>
  </section>

  <div class="page-actions">
    <%= link_to "一覧へ戻る", shift_periods_path, class: "button button-ghost" %>
  </div>
</section>
