<h1>シフト期間詳細</h1>

<p><strong>名称:</strong> <%= @shift_period.name %></p>
<p><strong>開始日:</strong> <%= @shift_period.start_date %></p>
<p><strong>終了日:</strong> <%= @shift_period.end_date %></p>
<p><strong>状態:</strong> <%= @shift_period.status %></p>

<h2>日別データ</h2>

<% @shift_period.shift_days.order(:target_date).each do |shift_day| %>
  <hr>
  <p>
    <strong>日付:</strong> <%= shift_day.target_date %>
    （<%= %w[日 月 火 水 木 金 土][shift_day.target_date.wday] %>）
    / <strong>種別:</strong> <%= shift_day.day_type %>
  </p>

  <% if shift_day.shift_assignments.any? %>
    <table>
      <thead>
        <tr>
          <th>ユーザー</th>
          <th>区</th>
          <th>勤務区分</th>
        </tr>
      </thead>
      <tbody>
        <% shift_day.shift_assignments.includes(:user, :zone).each do |assignment| %>
          <tr>
            <td><%= assignment.user.name %></td>
            <td><%= assignment.zone_id %></td>
            <td><%= assignment.work_type %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>割当はまだありません。</p>
  <% end %>

 <h3>割当を追加する</h3>

  <%= form_with model: [shift_day, ShiftAssignment.new], local: true do |f| %>
    <div>
      <%= f.label :user_id, "ユーザー" %><br>
      <%= f.collection_select :user_id, @users, :id, :name, prompt: "選択してください" %>
    </div>

    <div>
      <%= f.label :zone_id, "区" %><br>
      <%= f.collection_select :zone_id, @zones, :id, :name, prompt: "休みの場合は未選択" %>
    </div>

    <div>
      <%= f.label :work_type, "勤務区分" %><br>
      <%= f.select :work_type, ShiftAssignment.work_types.keys.map { |k| [k, k] }, prompt: "選択してください" %>
    </div>

    <div>
      <%= f.submit "登録する" %>
    </div>
  <% end %>
<% end %>

<p><%= link_to "一覧へ戻る", shift_periods_path %></p>
