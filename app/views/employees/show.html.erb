<section class="page-shell page-shell--narrow">
  <div class="page-header">
    <div>
      <p class="eyebrow">Staff</p>
      <h1 class="page-title">スタッフ詳細</h1>
      <p class="page-subtitle">個々の条件や担当区を、一目で把握しやすい形でまとめています。</p>
    </div>
    <div class="page-actions">
      <%= link_to '編集', edit_employee_path(@employee), class: "button button-primary" %>
      <%= link_to 'スタッフ一覧へ戻る', employees_path, class: "button button-ghost" %>
    </div>
  </div>

  <section class="card">
    <dl class="detail-list">
      <div>
        <dt>ID</dt>
        <dd><%= @employee.id %></dd>
      </div>
      <div>
        <dt>スタッフ名</dt>
        <dd><%= @employee.name %></dd>
      </div>
      <div>
        <dt>主担当区</dt>
        <dd><%= @employee.primary_zone&.name || '未設定' %></dd>
      </div>
      <div>
        <dt>担当可能区</dt>
        <dd><%= @employee.zones.order(:position).pluck(:name).join('、').presence || '未設定' %></dd>
      </div>
      <div>
        <dt>土日祝出勤不可</dt>
        <dd><%= @employee.weekend_work_disabled ? 'する' : 'しない' %></dd>
      </div>
      <% if @employee.has_attribute?(:mixed_zone_preferred) %>
        <div>
          <dt>混合区担当候補</dt>
          <dd><%= @employee.mixed_zone_preferred ? 'する' : 'しない' %></dd>
        </div>
      <% end %>
    </dl>
  </section>
</section>
