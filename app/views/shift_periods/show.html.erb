<h1>シフト期間詳細</h1>

<p><strong>名称:</strong> <%= @shift_period.name %></p>
<p><strong>開始日:</strong> <%= @shift_period.start_date %></p>
<p><strong>終了日:</strong> <%= @shift_period.end_date %></p>
<p><strong>状態:</strong> <%= @shift_period.status %></p>

<h2>日別データ</h2>

<% @shift_period.shift_days.order(:target_date).each do |shift_day| %>
  <hr>
  <p>
    <strong>日付:</strong> <%= shift_day.target_date %>
    （<%= %w[日 月 火 水 木 金 土][shift_day.target_date.wday] %>）
    / <strong>種別:</strong> <%= shift_day.day_type %>
  </p>

  <% if shift_day.shift_assignments.any? %>
    <table>
      <thead>
        <tr>
          <th>ユーザー</th>
          <th>区</th>
          <th>勤務区分</th>
        </tr>
      </thead>
      <tbody>
        <% shift_day.shift_assignments.includes(:user).each do |assignment| %>
          <tr>
            <td><%= assignment.user.name %></td>
            <td><%= assignment.zone_name %></td>
            <td><%= assignment.work_type %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>割当はまだありません。</p>
  <% end %>
<% end %>

<p><%= link_to "一覧へ戻る", shift_periods_path %></p>
