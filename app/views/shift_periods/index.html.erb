<section class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">シフト期間</p>
      <h1 class="page-title">シフト期間一覧</h1>
      <p class="page-subtitle">作成済みのシフト期間を確認できます。</p>
    </div>
    <div class="page-actions">
      <%= link_to "新しいシフト期間を作成", new_shift_period_path, class: "button button-primary" %>
      <%= link_to "トップページへ戻る", root_path, class: "button button-ghost" %>
    </div>
  </div>

  <section class="card">
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>名称</th>
            <th>開始日</th>
            <th>終了日</th>
            <th>状態</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @shift_periods.each do |shift_period| %>
            <tr>
              <td><strong><%= shift_period.name %></strong></td>
              <td><%= shift_period.start_date %></td>
              <td><%= shift_period.end_date %></td>
              <td><span class="status-pill"><%= shift_period_status_label(shift_period) %></span></td>
              <td class="table-actions">
                <%= link_to "詳細", shift_period_path(shift_period), class: "text-link" %>
                <%= link_to "編集", edit_shift_period_path(shift_period), class: "text-link" %>
                <% unless shift_period.locked? %>
                  <%= link_to "削除", shift_period_path(shift_period), class: "text-link text-link-danger", data: { turbo_method: :delete, turbo_confirm: "このシフト期間を削除しますか？" } %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
