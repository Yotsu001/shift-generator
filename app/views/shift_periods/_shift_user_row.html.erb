<tr>
  <th class="shift-staff-name"><%= employee.name %></th>

  <% shift_days.each do |shift_day| %>
    <% assignment = find_shift_assignment(shift_day, employee) %>
    <% leave_request = find_leave_request(shift_day, employee) %>

    <%= render "shift_cell",
          shift_day: shift_day,
          employee: employee,
          assignment: assignment,
          leave_request: leave_request %>
  <% end %>
</tr>