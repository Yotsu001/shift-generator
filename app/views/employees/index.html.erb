<section class="page-shell">
  <div class="page-header">
    <div>
      <p class="eyebrow">スタッフ</p>
      <h1 class="page-title">スタッフ一覧</h1>
      <p class="page-subtitle">担当区や勤務条件を確認できる一覧です。</p>
    </div>
    <div class="page-actions">
      <%= link_to "スタッフを新規登録", new_employee_path, class: "button button-primary" %>
      <%= link_to "トップページへ戻る", root_path, class: "button button-ghost" %>
    </div>
  </div>

  <section class="card">
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>スタッフ名</th>
            <th>主担当区</th>
            <th>担当可能区</th>
            <th>土日祝出勤不可</th>
            <th>混合区担当候補</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @employees.each do |employee| %>
            <tr>
              <td><%= employee.id %></td>
              <td><strong><%= employee.name %></strong></td>
              <td><%= employee.primary_zone&.name || '未設定' %></td>
              <td><%= employee.zones.order(:position).pluck(:name).join('、').presence || '未設定' %></td>
              <td><%= employee.weekend_work_disabled ? '○' : '-' %></td>
              <td><%= employee.mixed_zone_preferred ? '○' : '-' %></td>
              <td class="table-actions">
                <%= link_to '詳細', employee_path(employee), class: "text-link" %>
                <%= link_to '編集', edit_employee_path(employee), class: "text-link" %>
                <%= link_to '削除', employee_path(employee), class: "text-link text-link-danger", data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>


