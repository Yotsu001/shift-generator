<h1>シフト期間詳細</h1>

<%= render "shift_period_summary", shift_period: @shift_period %>

<h2>シフト表</h2>

<p style="margin-bottom: 16px;">
  <%= button_to "自動生成",
      generate_shift_period_path(@shift_period),
      method: :post %>

  <%= button_to "リセット",
      clear_assignments_shift_period_path(@shift_period),
      method: :delete,
      data: { turbo_confirm: "リセットしますか？" } %>
</p>

<%= render "shift_table", employees: @employees, shift_days: shift_days(@shift_period) %>

<p style="margin-top: 16px;">
  <%= link_to "一覧へ戻る", shift_periods_path %>
</p>