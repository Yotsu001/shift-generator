<% date_fields_disabled = @shift_period.persisted? && @shift_period.locked? %>

<%= form_with model: @shift_period, local: true, html: { class: "stacked-form shift-period-form" } do |f| %>
  <% if @shift_period.errors.any? %>
    <div class="error-messages">
      <ul>
        <% @shift_period.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, "名称" %>
    <%= f.text_field :name %>
  </div>

  <% use_plain_text_date_inputs = Rails.env.test? %>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :start_date, "開始日" %>
      <% if use_plain_text_date_inputs %>
        <%= f.text_field :start_date, disabled: date_fields_disabled %>
      <% else %>
        <%= f.date_field :start_date, class: "js-date-input", data: { disable_manual_entry: true }, disabled: date_fields_disabled %>
      <% end %>
    </div>

    <div class="form-group">
      <%= f.label :end_date, "終了日" %>
      <% if use_plain_text_date_inputs %>
        <%= f.text_field :end_date, disabled: date_fields_disabled %>
      <% else %>
        <%= f.date_field :end_date, class: "js-date-input", data: { disable_manual_entry: true }, disabled: date_fields_disabled %>
      <% end %>
    </div>
  </div>

  <% if date_fields_disabled %>
    <p class="form-hint">確定済みのため、日付は変更できません。</p>
  <% end %>

  <% if @shift_period.persisted? %>
    <div class="form-group">
      <%= f.label :status, "状態" %>
      <%= f.select :status, shift_period_status_options %>
    </div>
  <% else %>
    <div class="form-group">
      <label>状態</label>
      <input type="text" value="案" disabled>
      <p class="form-hint">作成時は自動的に「案」で登録されます。確定への変更は作成後に編集画面で行えます。</p>
    </div>
  <% end %>

  <div class="form-actions">
    <%= f.submit @shift_period.persisted? ? "更新する" : "作成する" %>
  </div>
<% end %>
