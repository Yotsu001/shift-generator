<section class="page-shell page-shell--narrow auth-page">
  <div class="page-header">
    <div>
      <p class="eyebrow">アカウント</p>
      <h1 class="page-title">新しいパスワードを設定</h1>
      <p class="page-subtitle">安全に再ログインできるよう、新しいパスワードを設定します。</p>
    </div>
  </div>

  <section class="card auth-card auth-card--form">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "stacked-form auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="form-group">
        <div class="auth-form__label-row">
          <%= f.label :password, "新しいパスワード" %>
          <% if @minimum_password_length %>
            <span class="form-hint"><%= @minimum_password_length %>文字以上</span>
          <% end %>
        </div>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "新しいパスワード（確認用）" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="form-actions">
        <%= f.submit "パスワードを更新する" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </section>
</section>
