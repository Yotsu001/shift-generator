<h1>シフト表作成アプリ</h1>

<% if user_signed_in? %>
  <p>ログイン中です</p>
  <p>ようこそ、<%= current_user.name %>さん</p>
  <p><%= current_user.email %></p>

  <p>
    <strong>担当可能区:</strong>
    <%= current_user.employee&.zones&.order(:position)&.pluck(:name)&.join("、").presence || "未設定" %>
  </p>

  <%= link_to "プロフィール編集", edit_user_registration_path %><br>
  <%= link_to "シフト期間一覧へ", shift_periods_path %>
  <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete } %>
<% else %>
  <p>ログインしていません</p>
  <%= link_to "新規登録", new_user_registration_path %>
  <%= link_to "ログイン", new_user_session_path %>
<% end %>
