<%= form_with model: @shift_period, local: true, html: { class: "stacked-form" } do |f| %>
  <% if @shift_period.errors.any? %>
    <div class="error-messages">
      <ul>
        <% @shift_period.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, "名称" %>
    <%= f.text_field :name %>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :start_date, "開始日" %>
      <%= f.date_field :start_date %>
    </div>

    <div class="form-group">
      <%= f.label :end_date, "終了日" %>
      <%= f.date_field :end_date %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :status, "状態" %>
    <%= f.select :status, shift_period_status_options %>
  </div>

  <div class="form-actions">
    <%= f.submit @shift_period.persisted? ? "更新する" : "作成する" %>
  </div>
<% end %>
