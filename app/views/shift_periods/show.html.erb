<section class="page-shell shift-page">
  <div class="page-header">
    <div>
      <p class="eyebrow">シフト期間</p>
      <h1 class="page-title">シフト期間詳細</h1>
      <p class="page-subtitle">期間情報とシフト表を同じ流れで確認できる、見通しのよい詳細画面です。</p>
    </div>
    <div class="page-actions">
      <% unless @shift_period.locked? %>
        <%= link_to "編集", edit_shift_period_path(@shift_period), class: "button button-secondary" %>
      <% end %>
      <%= link_to "一覧へ戻る", shift_periods_path, class: "button button-ghost" %>
    </div>
  </div>

  <section class="card">
    <%= render "shift_periods/shift_period_summary", shift_period: @shift_period %>
  </section>

  <section class="card">
    <div class="section-header">
      <div>
        <h2 class="section-title">シフト表</h2>
        <% if @shift_period.locked? %>
          <p class="section-copy">このシフト期間は確定済みのため、詳細画面では閲覧のみ可能です。</p>
        <% else %>
          <p class="section-copy">表の中で勤務登録、編集、希望休登録まで完結できます。</p>
        <% end %>
      </div>
      <% if @shift_period.locked? %>
        <p class="auth-note">このシフト期間は確定済みのため、詳細画面では編集・登録・削除を行えません。</p>
      <% else %>
        <div class="page-actions">
          <%= button_to "自動生成",
              generate_shift_period_path(@shift_period),
              method: :post,
              class: "button button-primary" %>

          <%= button_to "リセット",
              clear_assignments_shift_period_path(@shift_period),
              method: :delete,
              class: "button button-danger",
              data: { turbo_confirm: "リセットしますか？" } %>
        </div>
      <% end %>
    </div>

    <%= render "shift_periods/shift_table", employees: @employees, shift_days: shift_days(@shift_period) %>
  </section>
</section>
