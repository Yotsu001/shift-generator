<h1>スタッフ一覧</h1>

<p>
  <%= link_to 'スタッフを新規登録', new_employee_path %>
</p>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>スタッフ名</th>
      <th>担当区</th>
      <th>混合区候補</th>
      <th></th>
      <th></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @employees.each do |employee| %>
      <tr>
        <td><%= employee.id %></td>
        <td><%= employee.name %></td>
        <td><%= employee.primary_zone&.name || '未設定' %></td>
        <td><%= employee.mixed_zone_preferred ? '○' : '-' %></td>
        <td><%= link_to '詳細', employee_path(employee) %></td>
        <td><%= link_to '編集', edit_employee_path(employee) %></td>
        <td>
          <%= link_to '削除', employee_path(employee), data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<p style="margin-top: 16px;">
  <%= link_to "トップページへ戻る", root_path %>
</p>