<tr>
  <th class="sticky-col user-name-cell">
    <%= user.name %>
  </th>

  <% shift_days.each do |shift_day| %>
    <% assignment = assignments_map.dig(user.id, shift_day.id) %>

    <%= render "assignment_cell",
               user: user,
               shift_day: shift_day,
               assignment: assignment %>
  <% end %>
</tr>